{
    "name": "@keneth80/k-chart",
    "version": "1.15.0",
    "description": "Lightweight TypeScript D3 chart runtime with functional SVG, Canvas, and WebGL series renderers.",
    "main": "lib/index.js",
    "types": "lib/index.d.ts",
    "exports": {
        ".": {
            "types": "./lib/index.d.ts",
            "default": "./lib/index.js"
        },
        "./core": {
            "types": "./lib/core/index.d.ts",
            "default": "./lib/core/index.js"
        },
        "./series": {
            "types": "./lib/series/index.d.ts",
            "default": "./lib/series/index.js"
        },
        "./options": {
            "types": "./lib/options/index.d.ts",
            "default": "./lib/options/index.js"
        },
        "./presets": {
            "types": "./lib/presets/index.d.ts",
            "default": "./lib/presets/index.js"
        },
        "./utils": {
            "types": "./lib/utils/index.d.ts",
            "default": "./lib/utils/index.js"
        },
        "./worker": {
            "types": "./lib/worker/index.d.ts",
            "default": "./lib/worker/index.js"
        }
    },
    "files": [
        "lib/**/*",
        "README.md",
        "LICENSE",
        "CHANGELOG.md",
        "docs/*.md",
        "docs/assets/*",
        "examples/*.ts",
        "examples/*.tsx",
        "examples/stackblitz-*/index.html",
        "examples/stackblitz-*/package.json",
        "examples/stackblitz-*/package-lock.json",
        "examples/stackblitz-*/public/**/*",
        "examples/stackblitz-*/src/**/*"
    ],
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "result": "lite-server -c lite-server-config.json",
        "build": "npm run build:lib && npm run build-demo",
        "build:lib": "tsc -p tsconfig.lib.json",
        "build-demo": "cross-env NODE_ENV=development webpack --mode development",
        "build-prod": "cross-env NODE_ENV=production webpack --mode production",
        "typecheck": "tsc --noEmit",
        "dev": "webpack-dev-server --host 127.0.0.1 --port 9003 --mode development",
        "prepublishOnly": "npm run typecheck",
        "prepack": "npm run build:lib",
        "pack:dry": "npm pack --dry-run",
        "bundle-analyze": "webpack --profile --json > stats.json",
        "bundle-analyze-open": "webpack-bundle-analyzer stats.json --port=9900"
    },
    "keywords": [
        "d3",
        "typescript",
        "chart",
        "visualization",
        "canvas",
        "webgl",
        "svg"
    ],
    "author": "Kenneth Kang",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/keneth80/k-chart.git"
    },
    "bugs": {
        "url": "https://github.com/keneth80/k-chart/issues"
    },
    "homepage": "https://github.com/keneth80/k-chart#readme",
    "devDependencies": {
        "@babel/core": "^7.29.7",
        "@babel/plugin-proposal-decorators": "^7.29.7",
        "@babel/plugin-transform-class-properties": "^7.29.7",
        "@babel/plugin-transform-private-methods": "^7.29.7",
        "@babel/plugin-transform-private-property-in-object": "^7.29.7",
        "@babel/plugin-transform-runtime": "^7.29.7",
        "@babel/preset-env": "^7.29.7",
        "@babel/runtime-corejs3": "^7.29.7",
        "@types/d3": "^7.4.3",
        "@types/d3-array": "^3.2.2",
        "@types/d3-geo": "^3.1.0",
        "@types/d3-selection": "^3.0.11",
        "@types/d3-transition": "^3.0.9",
        "@types/d3-zoom": "^3.0.8",
        "@types/highlight.js": "^9.12.4",
        "@types/object-hash": "^1.3.3",
        "@types/topojson-client": "^3.1.5",
        "babel-loader": "^10.1.1",
        "browser-sync-client": "^2.26.13",
        "cesium": "^1.142.0",
        "clean-webpack-plugin": "^4.0.0",
        "copy-webpack-plugin": "^14.0.0",
        "core-js": "^3.49.0",
        "cross-env": "^10.1.0",
        "crossfilter2": "^1.4.8",
        "css-loader": "^7.1.4",
        "css-minimizer-webpack-plugin": "^8.0.0",
        "d3": "^7.9.0",
        "dsv-loader": "^2.0.0",
        "eslint": "^7.14.0",
        "highlight.js": "^10.4.0",
        "html-webpack-plugin": "^5.6.7",
        "lite-server": "^2.6.1",
        "maplibre-gl": "^5.24.0",
        "object-hash": "^2.0.3",
        "regenerator-runtime": "^0.14.1",
        "rxjs": "^6.5.5",
        "style-loader": "^4.0.0",
        "terser-webpack-plugin": "^5.6.1",
        "three": "^0.184.0",
        "ts-loader": "^9.6.0",
        "typescript": "^6.0.3",
        "webpack": "^5.107.2",
        "webpack-bundle-analyzer": "^5.3.0",
        "webpack-cli": "^7.0.3",
        "webpack-dev-server": "^5.2.4",
        "webpack-merge": "^6.0.1"
    },
    "dependencies": {
        "d3-array": "^3.2.4",
        "d3-axis": "^3.0.0",
        "d3-geo": "^3.1.1",
        "d3-scale": "^4.0.2",
        "d3-scale-chromatic": "^3.1.0",
        "d3-selection": "^3.0.0",
        "d3-shape": "^3.2.0",
        "d3-zoom": "^3.0.0",
        "topojson-client": "^3.1.0",
        "world-atlas": "^2.0.2"
    }
}
