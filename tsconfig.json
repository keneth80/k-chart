{
    "compilerOptions": {
        // leave JSX as it is
        // resolve modules as you would expect
        "moduleResolution": "node",
        // leave imports as they are
        "module": "es2020",
        // do not transpile stuff like classes, async/await, ...
        "target": "es5",
        "lib": [
            "es2015", "es6", "esnext", "dom"
        ],
        "declaration": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "strict": false,
        "noImplicitAny": false,
        "strictNullChecks": false,
        "strictPropertyInitialization": false,
        "skipLibCheck": true,
        // produce a source map
        "sourceMap": true,
        "rootDir": ".",
        "baseUrl": ".",
        "ignoreDeprecations": "6.0",
        "outDir": "dist",
        "paths": {
          "@keneth80/k-chart": ["./src/index.ts"],
          "@keneth80/k-chart/core": ["./src/core/index.ts"],
          "@keneth80/k-chart/options": ["./src/options/index.ts"],
          "@keneth80/k-chart/presets": ["./src/presets/index.ts"],
          "@keneth80/k-chart/series": ["./src/series/index.ts"],
          "@keneth80/k-chart/utils": ["./src/utils/index.ts"],
          "@keneth80/k-chart/worker": ["./src/worker/index.ts"],
          "components/*": ["./src/components/*"],
          "assets/*": ["./src/assets/*"]
        },
        "allowSyntheticDefaultImports": true
    },
    "include": [
        "./src/**/*"
    ],
    "exclude": [
        "./node_modules/**/*",
        "./src/main copy.ts"
    ]
}
